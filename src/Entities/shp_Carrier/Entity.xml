<?xml version="1.0" encoding="utf-8"?>
<Entity xmlns="http://schemas.microsoft.com/xrm/2011/metadata">
  <Name>shp_carrier</Name>
  <DisplayName>Carrier</DisplayName>
  <PluralName>Carriers</PluralName>
  <Description></Description>
  <HasActivities>false</HasActivities>
  <IsActivity>false</IsActivity>
  <OwnershipType>OrganizationOwned</OwnershipType>
  <Attributes>
    <Attribute>
      <Name>shp_carriername</Name>
      <DisplayName>Carrier Name</DisplayName>
      <Description>The name of the carrier</Description>
      <Type>String</Type>
      <RequiredLevel>ApplicationRequired</RequiredLevel>
      <MaxLength>100</MaxLength>
      <IsPrimaryName>true</IsPrimaryName>
    </Attribute>
    <Attribute>
      <Name>shp_scaccode</Name>
      <DisplayName>SCAC Code</DisplayName>
      <Description>Standard Carrier Alpha Code</Description>
      <Type>String</Type>
      <RequiredLevel>None</RequiredLevel>
      <MaxLength>10</MaxLength>
    </Attribute>
    <Attribute>
      <Name>shp_country</Name>
      <DisplayName>Country</DisplayName>
      <Description>The country where the carrier operates</Description>
      <Type>String</Type>
      <RequiredLevel>None</RequiredLevel>
      <MaxLength>100</MaxLength>
    </Attribute>
    <Attribute>
      <Name>shp_contactemail</Name>
      <DisplayName>Contact Email</DisplayName>
      <Description>Email address for carrier contact</Description>
      <Type>String</Type>
      <RequiredLevel>None</RequiredLevel>
      <MaxLength>200</MaxLength>
    </Attribute>
    <Attribute>
      <Name>shp_isactive</Name>
      <DisplayName>Is Active</DisplayName>
      <Description>Indicates whether the carrier is active</Description>
      <Type>Boolean</Type>
      <RequiredLevel>None</RequiredLevel>
      <DefaultValue>true</DefaultValue>
    </Attribute>
  </Attributes>
</Entity>
