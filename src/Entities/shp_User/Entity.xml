<?xml version="1.0" encoding="utf-8"?>
<Entity xmlns="http://schemas.microsoft.com/xrm/2011/metadata">
  <Name>shp_user</Name>
  <DisplayName>User</DisplayName>
  <PluralName>Users</PluralName>
  <Description></Description>
  <HasActivities>false</HasActivities>
  <IsActivity>false</IsActivity>
  <OwnershipType>UserOwned</OwnershipType>
  <Attributes>
    <Attribute>
      <Name>shp_fullname</Name>
      <DisplayName>Full Name</DisplayName>
      <Description>The full name of the user</Description>
      <Type>String</Type>
      <RequiredLevel>ApplicationRequired</RequiredLevel>
      <MaxLength>100</MaxLength>
      <IsPrimaryName>true</IsPrimaryName>
    </Attribute>
    <Attribute>
      <Name>shp_email</Name>
      <DisplayName>Email</DisplayName>
      <Description>Email address of the user</Description>
      <Type>String</Type>
      <RequiredLevel>ApplicationRequired</RequiredLevel>
      <MaxLength>200</MaxLength>
    </Attribute>
    <Attribute>
      <Name>shp_role</Name>
      <DisplayName>Role</DisplayName>
      <Description>The role assigned to the user</Description>
      <Type>Picklist</Type>
      <RequiredLevel>ApplicationRequired</RequiredLevel>
      <OptionSet>
        <Option value="100000000">
          <Label>Admin</Label>
        </Option>
        <Option value="100000001">
          <Label>User</Label>
        </Option>
        <Option value="100000002">
          <Label>ReadOnly</Label>
        </Option>
      </OptionSet>
    </Attribute>
    <Attribute>
      <Name>shp_isactive</Name>
      <DisplayName>Is Active</DisplayName>
      <Description>Indicates whether the user is active</Description>
      <Type>Boolean</Type>
      <RequiredLevel>None</RequiredLevel>
      <DefaultValue>true</DefaultValue>
    </Attribute>
    <Attribute>
      <Name>shp_lastlogin</Name>
      <DisplayName>Last Login</DisplayName>
      <Description>The date and time of the user's last login</Description>
      <Type>DateTime</Type>
      <RequiredLevel>None</RequiredLevel>
    </Attribute>
    <Attribute>
      <Name>shp_branchid</Name>
      <DisplayName>Branch</DisplayName>
      <Description>The branch the user is assigned to</Description>
      <Type>Lookup</Type>
      <RequiredLevel>ApplicationRequired</RequiredLevel>
      <LookupTargets>
        <LookupTarget>shp_branch</LookupTarget>
      </LookupTargets>
    </Attribute>
  </Attributes>
</Entity>
