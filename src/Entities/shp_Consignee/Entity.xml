<?xml version="1.0" encoding="utf-8"?>
<Entity xmlns="http://schemas.microsoft.com/xrm/2011/metadata">
  <Name>shp_consignee</Name>
  <DisplayName>Consignee</DisplayName>
  <PluralName>Consignees</PluralName>
  <Description></Description>
  <HasActivities>false</HasActivities>
  <IsActivity>false</IsActivity>
  <OwnershipType>OrganizationOwned</OwnershipType>
  <Attributes>
    <Attribute>
      <Name>shp_consigneename</Name>
      <DisplayName>Consignee Name</DisplayName>
      <Description>The name of the consignee</Description>
      <Type>String</Type>
      <RequiredLevel>ApplicationRequired</RequiredLevel>
      <MaxLength>100</MaxLength>
      <IsPrimaryName>true</IsPrimaryName>
    </Attribute>
    <Attribute>
      <Name>shp_country</Name>
      <DisplayName>Country</DisplayName>
      <Description>The country where the consignee is located</Description>
      <Type>String</Type>
      <RequiredLevel>None</RequiredLevel>
      <MaxLength>100</MaxLength>
    </Attribute>
    <Attribute>
      <Name>shp_taxid</Name>
      <DisplayName>Tax ID</DisplayName>
      <Description>The tax identification number of the consignee</Description>
      <Type>String</Type>
      <RequiredLevel>None</RequiredLevel>
      <MaxLength>50</MaxLength>
    </Attribute>
    <Attribute>
      <Name>shp_contactemail</Name>
      <DisplayName>Contact Email</DisplayName>
      <Description>Email address for consignee contact</Description>
      <Type>String</Type>
      <RequiredLevel>None</RequiredLevel>
      <MaxLength>200</MaxLength>
    </Attribute>
    <Attribute>
      <Name>shp_isactive</Name>
      <DisplayName>Is Active</DisplayName>
      <Description>Indicates whether the consignee is active</Description>
      <Type>Boolean</Type>
      <RequiredLevel>None</RequiredLevel>
      <DefaultValue>true</DefaultValue>
    </Attribute>
  </Attributes>
</Entity>
